# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# FIREBASE_SERVICE_ACCOUNT_KEY: Full service-account JSON (stringified) for the
# Admin SDK. On Vercel this is REQUIRED — the Admin SDK bypasses Firestore
# security rules, which are locked to deny-all client access. Set it locally too
# to exercise the production (Admin SDK) code path.
FIREBASE_SERVICE_ACCOUNT_KEY=

# FIREBASE_DATABASE_ID: Optional. Defaults to "(default)".
FIREBASE_DATABASE_ID=

# SERVER_PEPPER: REQUIRED for secure voting. Secret salt mixed into the
# SHA-256 credential and OTP hashes. There is NO hardcoded fallback — if this
# is unset the OTP/vote endpoints refuse to operate. Use a long random string
# and NEVER commit the real value. Generate e.g.:  openssl rand -hex 32
SERVER_PEPPER=

# RESEND_API_KEY: API key for delivering OTP emails via Resend. If unset, the
# server falls back to a log-only sender (codes printed to the server log) —
# fine for local dev, NOT acceptable in production.
RESEND_API_KEY=

# OTP_FROM_EMAIL: Verified sender address for OTP emails (e.g.
# "KKTC Anket <no-reply@yourdomain.com>"). Defaults to onboarding@resend.dev
# for testing.
OTP_FROM_EMAIL=

# SECURE_VOTING_ENABLED: Secure (OTP single-cast) flow is ON unless set to
# exactly "false". Leaving it unset keeps secure voting enabled.
SECURE_VOTING_ENABLED=

# ELECTION_CLOSED: Set to "true" to reject all new votes (polls closed).
ELECTION_CLOSED=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
